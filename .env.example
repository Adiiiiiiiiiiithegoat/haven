# Copy this file to ".env" and fill in your keys.
# The .env file is gitignored and must NEVER be committed.

# Add up to 4 Groq API keys. On a rate limit (429), the server tries the next key
# immediately — no waiting. At least one key is required.
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Single-key fallback (still works if you only have one key):
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# PORT=8787
# HAVEN_MODEL=llama-3.3-70b-versatile
