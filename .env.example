# Copy this file to ".env" and fill in your keys.
# The .env file is gitignored and must NEVER be committed.

# Add up to 4 Groq API keys. On a failure the server tries the next key
# immediately — a rate limit (429), a bad/revoked key (401/403), or a 5xx all
# fall through to the next key. At least one key is required. Tried in order:
#   _1 -> _2 -> _3 -> _4 -> GROQ_API_KEY  (the plain one is tried LAST).
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tried LAST — ideal slot for a paid "ultimate fallback" key:
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# PORT=8787
# HAVEN_MODEL=llama-3.3-70b-versatile
